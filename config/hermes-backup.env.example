# Placeholder-only example. `scripts/configure.sh` writes the real local file outside the repo.
# Future bootstrap should create a chmod-600 local env file, not edit this file.

B2_ACCOUNT_ID=PLACEHOLDER_B2_KEY_ID
B2_ACCOUNT_KEY=PLACEHOLDER_B2_APPLICATION_KEY
RESTIC_REPOSITORY=EXAMPLE_RESTIC_REPOSITORY
RESTIC_PASSWORD_FILE=EXAMPLE_LOCAL_RESTIC_PASSWORD_FILE_PATH
TELEGRAM_BOT_TOKEN=PLACEHOLDER_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=PLACEHOLDER_TELEGRAM_CHAT_ID
HERMES_BACKUP_CONFIG_DIR=EXAMPLE_LOCAL_CONFIG_DIR
HERMES_BACKUP_LOG_DIR=EXAMPLE_LOCAL_LOG_DIR
HERMES_BACKUP_STAGING_DIR=EXAMPLE_LOCAL_STAGING_DIR
HERMES_BACKUP_RESTORE_DIR=EXAMPLE_SAFE_RESTORE_DIR
# Optional: override the shared non-blocking runtime lock path. Default is $XDG_STATE_HOME/hermes-backup/run.lock or ~/.local/state/hermes-backup/run.lock.
# HERMES_BACKUP_LOCK_FILE=EXAMPLE_LOCAL_STATE_LOCK_FILE
# Optional: uncomment only when the restic snapshot host differs from the current hostname during recovery.
# HERMES_BACKUP_RESTORE_HOST=EXAMPLE_SOURCE_HOST
